{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "homepages",
  "main": "./src/worker.js",
  "compatibility_date": "2026-04-22",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "MESSAGE_RATE_LIMIT"
    }
  ]
}
