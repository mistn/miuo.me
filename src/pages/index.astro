---
import "../styles/global.css";

const profile = {
  name: "miuo",
  role: "Developer / Maker",
  intro:
    "I build small, focused web projects and keep notes on design, code, music, and open source.",
  email: "hi@miuo.me",
};

const siteUrl = "https://miuo.me";
const pageTitle = `${profile.name} - Developer / Maker`;
const pageDescription =
  "Personal homepage of miuo, a developer and maker building small web projects and writing notes on design, code, music, and open source.";
const previewImage = `${siteUrl}/home-bg.png`;
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  url: siteUrl,
  email: `mailto:${profile.email}`,
  jobTitle: profile.role,
  sameAs: ["https://blog.miuo.me"],
};

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={previewImage} />
    <meta property="og:site_name" content={profile.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={previewImage} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preload" href="/avatar.avif" as="image" type="image/avif" />
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme =
        storedTheme === "dark" || storedTheme === "light"
          ? storedTheme
          : prefersDark
            ? "dark"
            : "light";
    </script>
    <script
      is:inline
      defer
      src="https://umami.miuo.me/script.js"
      data-website-id="8624de9e-d27f-492b-a47d-51d5f3bfcc58"></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="home">
      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        aria-label="Switch to dark theme"
        title="Toggle theme"
      >
        <span class="theme-cord" aria-hidden="true"></span>
        <span class="theme-pull" aria-hidden="true"></span>
      </button>

      <section class="hero" id="about" aria-labelledby="home-title">
        <div class="profile-card">
          <img
            class="profile-avatar"
            src="/avatar.avif"
            alt=""
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <h1 id="home-title">{profile.name}</h1>
          <p class="eyebrow">{profile.role}</p>
          <p class="intro">{profile.intro}</p>

          <div class="actions">
            <button type="button" data-message-open>Message</button>
          </div>
        </div>

        <section class="terminal" data-draggable-window aria-label="Terminal profile">
          <div class="terminal-bar" data-drag-handle>
            <span></span>
            <span></span>
            <span></span>
            <strong>home - bash</strong>
          </div>
          <div class="terminal-screen">
            <p><b>guest@home</b> <span>~</span> ./about.sh</p>
            <p>miuo</p>
            <p>Developer / Maker</p>
            <p>Small web projects, notes, music, and open source.</p>
            <p><b>guest@home</b> <span>~</span> cat links.txt</p>
            <p>Blog <a href="https://blog.miuo.me">blog.miuo.me</a></p>
            <p>Email <a href={`mailto:${profile.email}`}>{profile.email}</a></p>
            <p><b>guest@home</b> <span>~</span> cat now.txt</p>
            <p>Building a small homepage, tuning styles, keeping things simple.</p>
            <p><b>guest@home</b> <span>~</span> <i aria-hidden="true"></i></p>
          </div>
        </section>
      </section>

      <p class="copyright">&copy; 2026 {profile.name}</p>

      <dialog class="message-dialog" data-message-dialog aria-labelledby="message-title">
        <form class="message-form" data-message-form action="/api/message" method="post">
          <div class="message-header">
            <h2 id="message-title">Message</h2>
            <button type="button" data-message-close aria-label="Close message form">
              &times;
            </button>
          </div>

          <label>
            <span>Name</span>
            <input name="name" type="text" autocomplete="name" maxlength="80" />
          </label>

          <label>
            <span>Email</span>
            <input name="email" type="email" autocomplete="email" maxlength="160" required />
          </label>

          <label>
            <span>Message</span>
            <textarea name="message" rows="5" maxlength="2000" required></textarea>
          </label>

          <input
            class="message-trap"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="turnstile-slot" data-turnstile-slot></div>

          <p class="message-status" data-message-status aria-live="polite"></p>

          <button class="message-submit" type="submit">Send</button>
        </form>
      </dialog>
    </main>
    <script>
      const themeToggle = document.querySelector("[data-theme-toggle]");
      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");

      function applyTheme(theme: "light" | "dark") {
        document.documentElement.dataset.theme = theme;
        if (themeToggle instanceof HTMLButtonElement) {
          themeToggle.setAttribute(
            "aria-label",
            theme === "dark" ? "Switch to light theme" : "Switch to dark theme",
          );
        }
      }

      applyTheme(document.documentElement.dataset.theme === "dark" ? "dark" : "light");

      if (themeToggle instanceof HTMLButtonElement) {
        const themeToggleButton = themeToggle;
        let pullStartX = 0;
        let pullStartY = 0;
        let pullX = 0;
        let pullY = 0;
        let pullTravel = 0;
        let pullVelocityX = 0;
        let pullVelocityY = 0;
        let lastPullX = 0;
        let lastPullY = 0;
        let lastPullTime = 0;
        let springFrame = 0;
        let isPullingTheme = false;
        let suppressThemeClick = false;

        function stopSpring() {
          if (!springFrame) return;
          cancelAnimationFrame(springFrame);
          springFrame = 0;
        }

        function setPullOffset(x: number, y: number) {
          const baseLength =
            Number.parseFloat(getComputedStyle(themeToggleButton).getPropertyValue("--cord-length")) ||
            54;
          const maxPullX =
            Number.parseFloat(getComputedStyle(themeToggleButton).getPropertyValue("--pull-limit-x")) ||
            34;
          const maxPullY =
            Number.parseFloat(getComputedStyle(themeToggleButton).getPropertyValue("--pull-limit-y")) ||
            38;
          pullX = Math.max(-maxPullX, Math.min(x, maxPullX));
          pullY = Math.max(0, Math.min(y, maxPullY));
          pullTravel = Math.hypot(pullX, pullY);

          const cordLength = Math.hypot(baseLength + pullY, pullX);
          const cordAngle = -Math.atan2(pullX, baseLength + pullY) * (180 / Math.PI);

          if (pullX === 0 && pullY === 0) {
            themeToggleButton.style.removeProperty("--pull-x");
            themeToggleButton.style.removeProperty("--pull-y");
            themeToggleButton.style.removeProperty("--cord-visual-length");
            themeToggleButton.style.removeProperty("--cord-angle");
            return;
          }

          themeToggleButton.style.setProperty("--pull-x", `${pullX}px`);
          themeToggleButton.style.setProperty("--pull-y", `${pullY}px`);
          themeToggleButton.style.setProperty("--cord-visual-length", `${cordLength}px`);
          themeToggleButton.style.setProperty("--cord-angle", `${cordAngle}deg`);
        }

        function releasePull(startVelocityX = pullVelocityX, startVelocityY = pullVelocityY) {
          stopSpring();
          let x = pullX;
          let y = pullY;
          let velocityX = startVelocityX;
          let velocityY = startVelocityY;
          let lastTime = performance.now();

          function tick(time: number) {
            const delta = Math.min((time - lastTime) / 1000, 0.032);
            lastTime = time;

            const stiffness = 520;
            const damping = 30;
            const accelerationX = -stiffness * x - damping * velocityX;
            const accelerationY = -stiffness * y - damping * velocityY;

            velocityX += accelerationX * delta;
            velocityY += accelerationY * delta;
            x += velocityX * delta;
            y += velocityY * delta;

            if (Math.abs(x) < 0.08 && Math.abs(y) < 0.08 && Math.hypot(velocityX, velocityY) < 2) {
              setPullOffset(0, 0);
              springFrame = 0;
              return;
            }

            setPullOffset(x, y);
            springFrame = requestAnimationFrame(tick);
          }

          springFrame = requestAnimationFrame(tick);
        }

        function toggleTheme() {
          const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
          localStorage.setItem("theme", nextTheme);
          applyTheme(nextTheme);
        }

        themeToggleButton.addEventListener("click", () => {
          if (suppressThemeClick) {
            suppressThemeClick = false;
            return;
          }
          if (pullTravel > 8) return;
          toggleTheme();
          setPullOffset(0, 12);
          releasePull(0, 0);
        });

        themeToggleButton.addEventListener("pointerdown", (event) => {
          stopSpring();
          isPullingTheme = true;
          pullStartX = event.clientX;
          pullStartY = event.clientY;
          lastPullX = 0;
          lastPullY = 0;
          lastPullTime = performance.now();
          pullVelocityX = 0;
          pullVelocityY = 0;
          setPullOffset(0, 0);
          themeToggleButton.setPointerCapture(event.pointerId);
        });

        themeToggleButton.addEventListener("pointermove", (event) => {
          if (!isPullingTheme) return;
          const nextX = event.clientX - pullStartX;
          const nextY = event.clientY - pullStartY;
          const now = performance.now();
          const delta = Math.max((now - lastPullTime) / 1000, 0.001);

          pullVelocityX = (nextX - lastPullX) / delta;
          pullVelocityY = (nextY - lastPullY) / delta;
          lastPullX = nextX;
          lastPullY = nextY;
          lastPullTime = now;

          setPullOffset(nextX, nextY);
        });

        themeToggleButton.addEventListener("pointerup", (event) => {
          if (!isPullingTheme) return;
          isPullingTheme = false;
          if (pullY > 18) {
            toggleTheme();
            suppressThemeClick = true;
          } else if (pullTravel > 8) {
            suppressThemeClick = true;
          }
          releasePull();
          themeToggleButton.releasePointerCapture(event.pointerId);
        });

        themeToggleButton.addEventListener("pointercancel", () => {
          isPullingTheme = false;
          releasePull();
        });

        window.addEventListener("resize", () => {
          if (isPullingTheme) return;
          setPullOffset(0, 0);
        });
      }

      systemTheme.addEventListener("change", (event) => {
        const storedTheme = localStorage.getItem("theme");
        if (storedTheme === "dark" || storedTheme === "light") return;
        applyTheme(event.matches ? "dark" : "light");
      });

      const terminal = document.querySelector("[data-draggable-window]");
      const handle = document.querySelector("[data-drag-handle]");

      if (terminal instanceof HTMLElement && handle instanceof HTMLElement) {
        const terminalWindow = terminal;
        const dragHandle = handle;
        let startX = 0;
        let startY = 0;
        let originX = 0;
        let originY = 0;
        let dragging = false;

        function moveWindow(x: number, y: number) {
          if (window.matchMedia("(max-width: 860px)").matches) return;
          const nextX = originX + x - startX;
          const nextY = originY + y - startY;
          terminalWindow.style.setProperty("--drag-x", `${nextX}px`);
          terminalWindow.style.setProperty("--drag-y", `${nextY}px`);
        }

        dragHandle.addEventListener("pointerdown", (event) => {
          if (window.matchMedia("(max-width: 860px)").matches) return;
          dragging = true;
          startX = event.clientX;
          startY = event.clientY;
          originX = Number.parseFloat(terminalWindow.style.getPropertyValue("--drag-x")) || 0;
          originY = Number.parseFloat(terminalWindow.style.getPropertyValue("--drag-y")) || 0;
          dragHandle.setPointerCapture(event.pointerId);
        });

        dragHandle.addEventListener("pointermove", (event) => {
          if (!dragging) return;
          moveWindow(event.clientX, event.clientY);
        });

        dragHandle.addEventListener("pointerup", (event) => {
          dragging = false;
          dragHandle.releasePointerCapture(event.pointerId);
        });

        dragHandle.addEventListener("pointercancel", () => {
          dragging = false;
        });
      }

      const openMessage = document.querySelector("[data-message-open]");
      const closeMessage = document.querySelector("[data-message-close]");
      const messageDialog = document.querySelector("[data-message-dialog]");
      const messageForm = document.querySelector("[data-message-form]");
      const messageStatus = document.querySelector("[data-message-status]");
      const turnstileSlot = document.querySelector("[data-turnstile-slot]");
      let turnstileScript: Promise<void> | null = null;
      let turnstileRendered = false;

      function loadTurnstileScript() {
        if (turnstileScript) return turnstileScript;
        turnstileScript = new Promise((resolve, reject) => {
          const script = document.createElement("script");
          script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
          script.async = true;
          script.defer = true;
          script.dataset.turnstileScript = "true";
          script.addEventListener("load", () => resolve(), { once: true });
          script.addEventListener("error", () => reject(), { once: true });
          document.head.append(script);
        });
        return turnstileScript;
      }

      async function renderTurnstile() {
        if (!(turnstileSlot instanceof HTMLElement) || turnstileRendered) return;

        const configResponse = await fetch("/api/config", {
          headers: { accept: "application/json" },
        });
        const config = await configResponse.json().catch(() => ({}));
        const siteKey =
          typeof config.turnstileSiteKey === "string"
            ? config.turnstileSiteKey.trim()
            : "";
        if (!siteKey) return;

        await loadTurnstileScript();
        const turnstileWindow = window as Window & {
          turnstile?: {
            render: (
              container: HTMLElement,
              options: { sitekey: string; size?: "normal" | "compact" | "flexible" },
            ) => void;
            reset: () => void;
          };
        };
        if (!turnstileWindow.turnstile) {
          throw new Error("Turnstile script did not load.");
        }
        turnstileWindow.turnstile.render(turnstileSlot, {
          sitekey: siteKey,
          size: "flexible",
        });
        turnstileRendered = true;
      }

      if (
        openMessage instanceof HTMLButtonElement &&
        closeMessage instanceof HTMLButtonElement &&
        messageDialog instanceof HTMLDialogElement &&
        messageForm instanceof HTMLFormElement &&
        messageStatus instanceof HTMLElement
      ) {
        openMessage.addEventListener("click", () => {
          messageStatus.textContent = "";
          messageDialog.showModal();
          renderTurnstile().catch(() => {
            messageStatus.textContent = "Message verification could not load.";
          });
        });

        closeMessage.addEventListener("click", () => {
          messageDialog.close();
        });

        messageDialog.addEventListener("click", (event) => {
          if (event.target === messageDialog) {
            messageDialog.close();
          }
        });

        messageForm.addEventListener("submit", async (event) => {
          event.preventDefault();

          const submitButton = messageForm.querySelector("button[type='submit']");
          const formData = new FormData(messageForm);
          const turnstile = window as Window & {
            turnstile?: { reset: () => void };
          };

          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = true;
          }

          messageStatus.textContent = "Sending...";

          try {
            const response = await fetch(messageForm.action, {
              method: "POST",
              headers: {
                "content-type": "application/json",
              },
              body: JSON.stringify({
                name: formData.get("name"),
                email: formData.get("email"),
                message: formData.get("message"),
                website: formData.get("website"),
                turnstileToken: formData.get("cf-turnstile-response"),
              }),
            });
            const result = await response.json().catch(() => ({}));

            messageStatus.textContent =
              typeof result.message === "string"
                ? result.message
                : response.ok
                  ? "Thanks, your message was sent."
                  : "Could not send your message right now.";

            if (response.ok) {
              messageForm.reset();
              turnstile.turnstile?.reset();
            }
          } catch {
            messageStatus.textContent = "Could not send your message right now.";
          } finally {
            if (submitButton instanceof HTMLButtonElement) {
              submitButton.disabled = false;
            }
          }
        });
      }
    </script>
  </body>
</html>
