---
import "../styles/global.css";

const profile = {
  name: "miuo",
  role: "Developer / Maker",
  intro:
    "I build small, focused web projects and keep notes on design, code, music, and open source.",
  email: "hi@miuo.me",
};

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="A clean, single-page personal homepage built with Astro."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preload" href="/home-bg.avif" as="image" type="image/avif" />
    <link rel="preload" href="/avatar.avif" as="image" type="image/avif" />
    <script
      is:inline
      defer
      src="https://umami.miuo.me/script.js"
      data-website-id="8624de9e-d27f-492b-a47d-51d5f3bfcc58"></script>
    <title>{profile.name} - Home</title>
  </head>
  <body>
    <main class="home">
      <section class="hero" id="about" aria-labelledby="home-title">
        <div class="profile-card">
          <img
            class="profile-avatar"
            src="/avatar.avif"
            alt=""
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <h1 id="home-title">{profile.name}</h1>
          <p class="eyebrow">{profile.role}</p>
          <p class="intro">{profile.intro}</p>

          <div class="actions">
            <button type="button" data-message-open>Message</button>
          </div>
        </div>

        <section class="terminal" data-draggable-window aria-label="Terminal profile">
          <div class="terminal-bar" data-drag-handle>
            <span></span>
            <span></span>
            <span></span>
            <strong>home - bash</strong>
          </div>
          <div class="terminal-screen">
            <p><b>guest@home</b> <span>~</span> ./about.sh</p>
            <p>miuo</p>
            <p>Developer / Maker</p>
            <p>Small web projects, notes, music, and open source.</p>
            <p><b>guest@home</b> <span>~</span> cat links.txt</p>
            <p>Blog blog.miuo.me</p>
            <p>Email {profile.email}</p>
            <p><b>guest@home</b> <span>~</span> cat now.txt</p>
            <p>Quiet room, small tools, open notes.</p>
            <p><b>guest@home</b> <span>~</span> <i aria-hidden="true"></i></p>
          </div>
        </section>
      </section>

      <p class="copyright">&copy; 2026 / {profile.name}</p>

      <dialog class="message-dialog" data-message-dialog aria-labelledby="message-title">
        <form class="message-form" data-message-form action="/api/message" method="post">
          <div class="message-header">
            <h2 id="message-title">Message</h2>
            <button type="button" data-message-close aria-label="Close message form">
              &times;
            </button>
          </div>

          <label>
            <span>Name</span>
            <input name="name" type="text" autocomplete="name" maxlength="80" />
          </label>

          <label>
            <span>Email</span>
            <input name="email" type="email" autocomplete="email" maxlength="160" required />
          </label>

          <label>
            <span>Message</span>
            <textarea name="message" rows="5" maxlength="2000" required></textarea>
          </label>

          <input
            class="message-trap"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="turnstile-slot" data-turnstile-slot></div>

          <p class="message-status" data-message-status aria-live="polite"></p>

          <button class="message-submit" type="submit">Send</button>
        </form>
      </dialog>
    </main>
    <script>
      const terminal = document.querySelector("[data-draggable-window]");
      const handle = document.querySelector("[data-drag-handle]");

      if (terminal instanceof HTMLElement && handle instanceof HTMLElement) {
        const terminalWindow = terminal;
        const dragHandle = handle;
        let startX = 0;
        let startY = 0;
        let originX = 0;
        let originY = 0;
        let dragging = false;

        function moveWindow(x: number, y: number) {
          if (window.matchMedia("(max-width: 860px)").matches) return;
          const nextX = originX + x - startX;
          const nextY = originY + y - startY;
          terminalWindow.style.setProperty("--drag-x", `${nextX}px`);
          terminalWindow.style.setProperty("--drag-y", `${nextY}px`);
        }

        dragHandle.addEventListener("pointerdown", (event) => {
          if (window.matchMedia("(max-width: 860px)").matches) return;
          dragging = true;
          startX = event.clientX;
          startY = event.clientY;
          originX = Number.parseFloat(terminalWindow.style.getPropertyValue("--drag-x")) || 0;
          originY = Number.parseFloat(terminalWindow.style.getPropertyValue("--drag-y")) || 0;
          dragHandle.setPointerCapture(event.pointerId);
        });

        dragHandle.addEventListener("pointermove", (event) => {
          if (!dragging) return;
          moveWindow(event.clientX, event.clientY);
        });

        dragHandle.addEventListener("pointerup", (event) => {
          dragging = false;
          dragHandle.releasePointerCapture(event.pointerId);
        });

        dragHandle.addEventListener("pointercancel", () => {
          dragging = false;
        });
      }

      const openMessage = document.querySelector("[data-message-open]");
      const closeMessage = document.querySelector("[data-message-close]");
      const messageDialog = document.querySelector("[data-message-dialog]");
      const messageForm = document.querySelector("[data-message-form]");
      const messageStatus = document.querySelector("[data-message-status]");
      const turnstileSlot = document.querySelector("[data-turnstile-slot]");
      let turnstileScript: Promise<void> | null = null;
      let turnstileRendered = false;

      function loadTurnstileScript() {
        if (turnstileScript) return turnstileScript;
        turnstileScript = new Promise((resolve, reject) => {
          const script = document.createElement("script");
          script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
          script.async = true;
          script.defer = true;
          script.dataset.turnstileScript = "true";
          script.addEventListener("load", () => resolve(), { once: true });
          script.addEventListener("error", () => reject(), { once: true });
          document.head.append(script);
        });
        return turnstileScript;
      }

      async function renderTurnstile() {
        if (!(turnstileSlot instanceof HTMLElement) || turnstileRendered) return;

        const configResponse = await fetch("/api/config", {
          headers: { accept: "application/json" },
        });
        const config = await configResponse.json().catch(() => ({}));
        const siteKey =
          typeof config.turnstileSiteKey === "string"
            ? config.turnstileSiteKey.trim()
            : "";
        if (!siteKey) return;

        await loadTurnstileScript();
        const turnstileWindow = window as Window & {
          turnstile?: {
            render: (container: HTMLElement, options: { sitekey: string }) => void;
            reset: () => void;
          };
        };
        if (!turnstileWindow.turnstile) {
          throw new Error("Turnstile script did not load.");
        }
        turnstileWindow.turnstile.render(turnstileSlot, { sitekey: siteKey });
        turnstileRendered = true;
      }

      if (
        openMessage instanceof HTMLButtonElement &&
        closeMessage instanceof HTMLButtonElement &&
        messageDialog instanceof HTMLDialogElement &&
        messageForm instanceof HTMLFormElement &&
        messageStatus instanceof HTMLElement
      ) {
        openMessage.addEventListener("click", () => {
          messageStatus.textContent = "";
          messageDialog.showModal();
          renderTurnstile().catch(() => {
            messageStatus.textContent = "Message verification could not load.";
          });
        });

        closeMessage.addEventListener("click", () => {
          messageDialog.close();
        });

        messageDialog.addEventListener("click", (event) => {
          if (event.target === messageDialog) {
            messageDialog.close();
          }
        });

        messageForm.addEventListener("submit", async (event) => {
          event.preventDefault();

          const submitButton = messageForm.querySelector("button[type='submit']");
          const formData = new FormData(messageForm);
          const turnstile = window as Window & {
            turnstile?: { reset: () => void };
          };

          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = true;
          }

          messageStatus.textContent = "Sending...";

          try {
            const response = await fetch(messageForm.action, {
              method: "POST",
              headers: {
                "content-type": "application/json",
              },
              body: JSON.stringify({
                name: formData.get("name"),
                email: formData.get("email"),
                message: formData.get("message"),
                website: formData.get("website"),
                turnstileToken: formData.get("cf-turnstile-response"),
              }),
            });
            const result = await response.json().catch(() => ({}));

            messageStatus.textContent =
              typeof result.message === "string"
                ? result.message
                : response.ok
                  ? "Thanks, your message was sent."
                  : "Could not send your message right now.";

            if (response.ok) {
              messageForm.reset();
              turnstile.turnstile?.reset();
            }
          } catch {
            messageStatus.textContent = "Could not send your message right now.";
          } finally {
            if (submitButton instanceof HTMLButtonElement) {
              submitButton.disabled = false;
            }
          }
        });
      }
    </script>
  </body>
</html>
